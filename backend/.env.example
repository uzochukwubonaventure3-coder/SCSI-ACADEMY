# ─── SCSI Academy Backend — Environment Variables ────────────────────
# Copy this file to .env and fill in values

# ─── Server ───────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────────────────────────────────
# Local: postgresql://postgres:yourpassword@localhost:5432/scsi_academy
# Railway: auto-provided
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/scsi_academy

# ─── Frontend ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://scsi-academy.vercel.app

# ─── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_32_plus_random_chars_e.g._openssl_rand_hex_32
ADMIN_EMAIL=preciouseze156@gmail.com
ADMIN_PASSWORD_HASH=   # run: npm run hash-password YourPassword123

# ─── Email (Gmail App Password) ───────────────────────────────────────
# Gmail → Security → 2FA → App Passwords → generate
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=preciouseze156@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=SCSI Academy <preciouseze156@gmail.com>

# ─── Paystack ─────────────────────────────────────────────────────────
# dashboard.paystack.com → Settings → API Keys
# Use pk_test / sk_test for development, pk_live / sk_live for production
PAYSTACK_PUBLIC_KEY=pk_test_7b16f4670868cfc7d46e19cf78764b4cc9dba26b
PAYSTACK_SECRET_KEY=sk_test_93e6dfd34e90eb75522198f1d2dd79929b32672c

# ─── Content Prices (kobo — 100 kobo = ₦1) ───────────────────────────
PRICE_MONTHLY_KOBO=1000000     # ₦10,000
PRICE_QUARTERLY_KOBO=2500000   # ₦25,000

# ─── Cloudinary (Image Uploads) ───────────────────────────────────────
# cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=BONAVENTURE
CLOUDINARY_API_KEY=349542888888963
CLOUDINARY_API_SECRET=HavOXokCVxQKn_OfJEn0wo2zpcE
