# ─── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database ────────────────────────────────────────────────────────
# Railway PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Auth ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_secret_here

# ─── Frontend URL (used for CORS + email links) ───────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ─── Admin account ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
# Generate with: npm run hash-password YourSecurePassword
ADMIN_PASSWORD_HASH=$2b$12$...

# ─── Paystack ────────────────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_SECRET_KEY=sk_live_...

# ─── Cloudinary ──────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) ────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password

# ─── Plan prices in kobo ─────────────────────────────────────────────
PRICE_ACADEMY_KOBO=1500000
PRICE_1ON1_MONTHLY_KOBO=1500000
PRICE_1ON1_3M_KOBO=4000000
PRICE_1ON1_6M_KOBO=6000000
